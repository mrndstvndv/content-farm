@page "/"
@rendermode InteractiveServer
@using BlazorApp1.Services
@inject RedditService Reddit

<div class="min-h-screen bg-slate-950 text-slate-100 p-6 flex flex-col items-center justify-center">
    <div class="w-full max-w-4xl bg-slate-900 border border-slate-800 rounded-lg p-6">
        <h1 class="text-2xl font-bold text-center text-white mb-1">Reddit Title Card Generator</h1>
        <p class="text-slate-400 text-sm text-center mb-6">Enter a post URL to generate an image card</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Form -->
            <div class="space-y-4">
                <div class="flex flex-col gap-1">
                    <span class="text-xs font-semibold text-slate-400">Post URL</span>
                    <div class="flex gap-2">
                        <input @bind="url" class="bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white w-full" placeholder="https://www.reddit.com/r/..." />
                        <button @onclick="GetPost" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded">Fetch</button>
                    </div>
                </div>

                @if (error is not null)
                {
                    <div class="bg-red-950/40 border border-red-900 text-red-400 text-xs p-3 rounded">
                        @error
                    </div>
                }

                @if (post is not null)
                {
                    <div class="border-t border-slate-800 pt-4 space-y-4">
                        <div class="flex flex-col gap-1">
                            <span class="text-xs font-semibold text-slate-400">Title</span>
                            <textarea @bind="postTitle" rows="3" class="bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white w-full resize-y"></textarea>
                        </div>

                        <div class="grid grid-cols-3 gap-2">
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-semibold text-slate-400">Subreddit</span>
                                <input @bind="subredditName" class="bg-slate-800 border border-slate-700 rounded px-3 py-2 text-xs text-white" />
                            </div>
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-semibold text-slate-400">Icon Path</span>
                                <input @bind="subredditIconPath" class="bg-slate-800 border border-slate-700 rounded px-3 py-2 text-xs text-white" placeholder="URL/Path" />
                            </div>
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-semibold text-slate-400">Author</span>
                                <input @bind="username" class="bg-slate-800 border border-slate-700 rounded px-3 py-2 text-xs text-white" />
                            </div>
                        </div>

                        <div class="grid grid-cols-3 gap-2">
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-semibold text-slate-400">Votes</span>
                                <input @bind="votes" class="bg-slate-800 border border-slate-700 rounded px-3 py-2 text-xs text-white" />
                            </div>
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-semibold text-slate-400">Comments</span>
                                <input @bind="comments" class="bg-slate-800 border border-slate-700 rounded px-3 py-2 text-xs text-white" />
                            </div>
                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-semibold text-slate-400">Time Ago</span>
                                <input @bind="timeAgo" class="bg-slate-800 border border-slate-700 rounded px-3 py-2 text-xs text-white" />
                            </div>
                        </div>

                        <div class="flex items-center gap-2">
                            <input type="checkbox" id="lightThemeCheckbox" @bind="isLightTheme" class="accent-blue-600" />
                            <label for="lightThemeCheckbox" class="text-xs text-slate-300 cursor-pointer">Use Light Theme</label>
                        </div>

                        <button @onclick="GetTitleCard" class="bg-green-600 hover:bg-green-700 text-white text-sm font-semibold w-full py-2.5 rounded">
                            Generate Card
                        </button>
                    </div>
                }
            </div>

            <!-- Preview -->
            <div class="flex flex-col items-center justify-center border border-slate-800 rounded bg-slate-950/20 p-4 min-h-[400px]">
                @if (cardImageBase64 is not null)
                {
                    <img src="@cardImageBase64" class="max-w-full max-h-[500px] rounded shadow-lg" alt="Preview" />
                    <span class="mt-4 text-xs text-slate-500">
                        Saved: <code>/Volumes/realme/Dev/content-farm/reddit/ballers.png</code>
                    </span>
                }
                else
                {
                    <div class="text-slate-600 text-center">
                        <p class="text-sm">Preview will appear here after generation</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    string url = "https://www.reddit.com/r/buhaydigital/comments/1uf64ez/wfh_things_that_make_me_feel_rich_for_no_reason/";
    string subredditName = "r/buhaydigital";
    string subredditIconPath = "";
    string username = "username";
    string votes = "4.1K";
    string comments = "2.2K";
    string timeAgo = "2d ago";
    bool isLightTheme = false;
    
    string? error;
    PostData? post;
    string postTitle = "";
    string? cardImageBase64;

    public async Task GetPost()
    {
        error = null;
        post = null;
        cardImageBase64 = null;
        postTitle = "";
        username = "username";

        try
        {
            post = await Reddit.GetPost(url);
            postTitle = post.Title;
            username = post.Author;
            ExtractSubredditFromUrl();
        }
        catch (RedditFetchException ex)
        {
            error = ex.Message;
        }
        catch (RedditPostNotFoundException ex)
        {
            error = ex.Message;
        }
    }

    private void ExtractSubredditFromUrl()
    {
        if (string.IsNullOrEmpty(url)) return;
        try
        {
            var uri = new Uri(url);
            var segments = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
            for (int i = 0; i < segments.Length - 1; i++)
            {
                if (segments[i].Equals("r", StringComparison.OrdinalIgnoreCase))
                {
                    subredditName = $"r/{segments[i + 1]}";
                    return;
                }
            }
        }
        catch
        {
            // Keep default
        }
    }

    public async Task GetTitleCard()
    {
        if (post is null) return;
        error = null;

        try
        {
            var bytes = await Reddit.GenerateTitleCard(
                postTitle,
                subredditName,
                subredditIconPath,
                isLightTheme,
                votes,
                comments,
                timeAgo,
                username
            );
            cardImageBase64 = $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
        }
        catch (Exception ex)
        {
            error = $"Failed to generate card: {ex.Message}";
        }
    }
}
